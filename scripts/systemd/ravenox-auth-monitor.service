[Unit]
Description=Ravenox Auth Expiry Monitor
After=network.target

[Service]
Type=oneshot
ExecStart=/home/admin"@ravenox/scripts/auth-monitor.sh
# Configure notification channels via environment
Environment=WARN_HOURS=2
# Environment=NOTIFY_PHONE=+1234567890
# Environment=NOTIFY_NTFY.ravenox-alerts

[Install]
WantedBy=default.target
